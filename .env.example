# ── Payload CMS ──────────────────────────────────────────────
# Postgres connection (matches docker-compose.yml for local dev)
DATABASE_URI=postgres://bevora:bevora@localhost:5433/bevora
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-string

# First admin user, auto-created on first boot
PAYLOAD_ADMIN_EMAIL=admin@bevorasg.com
PAYLOAD_ADMIN_PASSWORD=ChangeMe!2026

# ── Site assistant (chat bot) ────────────────────────────────
# Claude API key — powers the chat widget (see lib/chatbot.ts + app/api/chat).
# Get one at https://console.anthropic.com/. Keep it server-side only.
ANTHROPIC_API_KEY=sk-ant-...

# ── Outgoing email (SMTP) ────────────────────────────────────
# Sends contact-form notifications + Payload admin emails. Leave SMTP_HOST blank
# to disable (emails get logged to the console instead).
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_USER=enquiries@bevorasg.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=enquiries@bevorasg.com
# Where contact-form notifications are sent (defaults to enquiries@bevorasg.com)
CONTACT_NOTIFY_TO=enquiries@bevorasg.com
